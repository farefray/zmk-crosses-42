            >;
        };

        // в”Җв”Җ L1: Symbols + Numbers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        //
        //  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
        //  в”Ӯ   `    в”Ӯ   1    в”Ӯ   2    в”Ӯ   3    в”Ӯ   4    в”Ӯ   5    в”Ӯ
        //  в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
        //  в”Ӯ   ~    в”Ӯ   !    в”Ӯ   @    в”Ӯ   #    в”Ӯ   $    в”Ӯ   %    в”Ӯ
        //  в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
        //  в”Ӯ   _    в”Ӯ   \    в”Ӯ   [    в”Ӯ   {    в”Ӯ   <    в”Ӯ   |    в”Ӯ
        //  в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
        //                             в”Ӯ        в”Ӯ        в”Ӯ[exit]  в”Ӯ
        //                             в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
        //
        //  в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ
        //  в”Ӯ   6    в”Ӯ   7    в”Ӯ   8    в”Ӯ   9    в”Ӯ   0    в”Ӯ  BSPC  в”Ӯ
        //  в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
        //  в”Ӯ   ^    в”Ӯ   &    в”Ӯ   (    в”Ӯ   )    в”Ӯ   *    в”Ӯ   +    в”Ӯ
        //  в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө
        //  в”Ӯ   >    в”Ӯ   }    в”Ӯ   ]    в”Ӯ   ;    в”Ӯ   :    в”Ӯ   ?    в”Ӯ
        //  в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
        //  в”Ӯ        в”Ӯ        в”Ӯ        в”Ӯ
        //  в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ
        //
        // Note: Тҗ accessible via Shift+\ (left-bottom row) while on this layer

        sym_layer {
            display-name = "Sym";
            bindings = <
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ  Left half  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
AS(GRAVE)   AS(N1)          AS(N2)          AS(N3)          AS(N4)          AS(N5)
&kp TILDE   &kp EXCL        &kp AT          &kp HASH        &kp DLLR        &kp PRCNT
&kp UNDER   &kp BSLH        &kp LBKT        &kp LBRC        &kp LT          &kp PIPE
                                            &trans          &trans          &to BASE
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ  Right half  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
AS(N6)      AS(N7)          AS(N8)          AS(N9)          AS(N0)          &kp BSPC
&kp CARET   &kp AMPS        &kp LPAR        &kp RPAR        &kp STAR        &kp PLUS
&kp GT      &kp RBRC        &kp RBKT        &kp SEMI        &kp COLON       &kp QMARK
&trans                      &trans          &trans
            >;
        };

        // в”Җв”Җ L2: Nav + Function в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        //
        //  Left: F-row top, one-shot mods home row, layer toggles bottom
        //  Right: F-row top, nav cluster home+bottom
        //
        //  Left thumbs:  PRSC | вҖ” | VOL-
        //  Right thumbs: (held) | VOL+ | MUTE

        nav_layer {
            display-name = "Nav";
            bindings = <
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ  Left half  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
&kp F12     &kp F1          &kp F2          &kp F3          &kp F4          &kp F5
&caps_word  &sk LCTRL       &sk LALT        &sk LGUI        &sk LSHFT       &trans
&to UKR     &to GAME        &to MOUSE       &trans          &trans          &trans
                                            &kp PSCRN       &trans          &kp C_VOL_DN
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ  Right half  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
&kp F6      &kp F7          &kp F8          &kp F9          &kp F10         &kp F11
&kp PG_UP   &kp HOME        &kp UP          &kp END         &kp INS         &trans
&kp PG_DN   &kp LEFT        &kp DOWN        &kp RIGHT       &kp C_MUTE      &bootloader
&trans                      &kp C_VOL_UP    &kp C_MUTE
            >;
        };

        // в”Җв”Җ L3: Mouse (toggle from L2) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        //
        // Trackballs are always active (no layer needed for movement).
        // This layer adds mouse buttons and scroll wheel keys as backup.
        // Left trackball = scroll, Right trackball = cursor (configured in
        // the Crosses shield overlay вҖ” not changed here).
        //
        //  Left:  EXIT top-left, MB1/MB2 on thumbs
        //  Right: MB1-MB5 on home row, scroll keys on bottom row

        mouse_layer {
            display-name = "Mouse";
            bindings = <
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ  Left half  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
&to BASE    &trans          &trans          &trans          &trans          &trans
&trans      &trans          &trans          &trans          &trans          &trans
&trans      &trans          &trans          &trans          &trans          &trans
                                            &trans          &mkp MB1        &mkp MB2
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ  Right half  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
&trans      &trans          &trans          &trans          &trans          &trans
&mkp MB4    &mkp MB1        &mkp MB2        &mkp MB3        &mkp MB5        &trans
&trans      &msc SCRL_UP    &msc SCRL_DOWN  &msc SCRL_LEFT  &msc SCRL_RIGHT &trans
&mkp MB1                    &mkp MB3        &trans
            >;
        };

        // в”Җв”Җ L4: Ukrainian QWERTY (Windows IME) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        //
        // Sends standard QWERTY keycodes; the Windows Ukrainian (QWERTY)
        // keyboard layout in the OS maps these to Cyrillic characters.
        //
        // USAGE:
        //   1. Win+Space вҶ’ switch OS input to Ukrainian
        //   2. Hold в–ҪNAV вҶ’ tap UKR вҶ’ release (firmware now on L4)
        //   3. Type Cyrillic via QWERTY positions
        //   4. Tap EXIT вҶ’ back to L0
        //   5. Win+Space вҶ’ switch OS input back to English
        //
        // Тҗ (33rd letter): hold в–ҪSYM thumb on UKR layer вҶ’ access L1's \ key
        //   вҶ’ Shift+\ in Ukrainian IME = Тҗ
        //
        // Auto-Shift is intentionally OFF on this layer (would break / вҶ’ ?).
        // Punctuation: period = / key,  comma = Shift+/ key
        //
        // Cyrillic mapping (QWERTY вҶ’ Cyrillic):
        //   Q=Рҷ  W=РҰ  E=РЈ  R=Рҡ  T=Р•  Y=Рқ  U=Р“  I=РЁ  O=Р©  P=Р—
        //   A=РӨ  S=РҶ  D=Р’  F=Рҗ  G=Рҹ  H=Р   J=Рһ  K=Рӣ  L=Р”  ;=Р–  '=Р„
        //   Z=РҜ  X=Р§  C=РЎ  V=Рң  B=Рҳ  N=Рў  M=Р¬  ,=Р‘  .=Р®  /=.  ]=РҮ  [=РҘ

        ukr_layer {
            display-name = "UKR";
            bindings = <
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ  Left half  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
&to BASE    &kp Q           &kp W           &kp E           &kp R           &kp T
&kp LBKT    &kp A           &kp S           &kp D           &kp F           &kp G
&trans      &kp Z           &kp X           &kp C           &kp V           &kp B
                                            &trans          &trans          &trans
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ  Right half  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
&kp Y       &kp U           &kp I           &kp O           &kp P           &kp BSPC
&kp H       &kp J           &kp K           &kp L           &kp SEMI        &kp SQT
&kp N       &kp M           &kp COMMA       &kp DOT         &kp FSLH        &kp RBKT
&trans                      &trans          &trans
            >;
        };

        // в”Җв”Җ L5: Gaming QWERTY (no HRM, no Auto-Shift) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        //
        // Pure direct key presses вҖ” no timing behaviors.
        // Multiple EXIT keys for easy escape mid-game.

        game_layer {
            display-name = "Game";
            bindings = <
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ  Left half  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
&kp ESC     &kp N1          &kp N2          &kp N3          &kp N4          &kp N5
&kp TAB     &kp Q           &kp W           &kp E           &kp R           &kp T
&kp LSHFT   &kp A           &kp S           &kp D           &kp F           &kp G
                                            &kp LCTRL       &kp SPACE       &kp LALT
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ  Right half  в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
&kp N6      &kp N7          &kp N8          &kp N9          &kp N0          &to BASE
&kp Y       &kp U           &kp I           &kp O           &kp P           &trans
&kp H       &kp J           &kp K           &kp L           &kp SEMI        &to BASE
&trans                      &to BASE        &trans
            >;
        };

    }; // end keymap
